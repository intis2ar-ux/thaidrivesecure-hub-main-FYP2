rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function dashboardUserDoc() {
      return firestore.get(/databases/(default)/documents/userWdboard/$(request.auth.uid));
    }

    function isActiveDashboardUser() {
      return signedIn()
        && dashboardUserDoc().data.role in ["admin", "staff"]
        && dashboardUserDoc().data.status != "disabled";
    }

    function orderData(orderId) {
      return firestore.get(/databases/(default)/documents/orders/$(orderId)).data;
    }

    function ownsOrder(orderId) {
      return signedIn()
        && (
          orderData(orderId).userId == request.auth.uid
          || (
            orderData(orderId).keys().hasAny(["customer"])
            && orderData(orderId).customer.userId == request.auth.uid
          )
        );
    }

    // Existing order-related uploads (receipts, passports, vehicle grants)
    match /orders/{orderId}/{fileName=**} {
      allow read, write: if isActiveDashboardUser() || ownsOrder(orderId);
    }

    // Insurance documents generated from the admin dashboard.
    match /insurance_documents/{applicationId}/{fileName} {
      allow read: if isActiveDashboardUser() || ownsOrder(applicationId);
      allow write: if isActiveDashboardUser();
    }

  }
}
