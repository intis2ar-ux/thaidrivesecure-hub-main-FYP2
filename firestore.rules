rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function dashboardUserDoc() {
      return get(/databases/$(database)/documents/userWdboard/$(request.auth.uid));
    }

    function isActiveDashboardUser() {
      return signedIn()
        && dashboardUserDoc().data.role in ["admin", "staff"]
        && dashboardUserDoc().data.status != "disabled";
    }

    function isAdmin() {
      return isActiveDashboardUser()
        && dashboardUserDoc().data.role == "admin";
    }

    function hasOwner(data) {
      return signedIn()
        && (
          data.userId == request.auth.uid
          || (data.keys().hasAny(["customer"]) && data.customer.userId == request.auth.uid)
        );
    }

    function canCreateOwnedOrder(data) {
      return signedIn()
        && (
          data.userId == request.auth.uid
          || (data.keys().hasAny(["customer"]) && data.customer.userId == request.auth.uid)
        );
    }

    function orderData(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId)).data;
    }

    function canReadOrder(orderId) {
      return isActiveDashboardUser() || hasOwner(orderData(orderId));
    }

    function safeCustomerOrderUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "documents",
        "receiptUrl",
        "status",
        "updatedAt"
      ])
      && request.resource.data.status in ["applied", "pending", "REUPLOAD_REQUIRED"];
    }

    function safeOwnDashboardProfileUpdate(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name",
          "fullName",
          "phone",
          "phoneNumber",
          "avatar",
          "avatarUrl",
          "lastLogin",
          "updatedAt"
        ])
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status;
    }

    // Dashboard users - each user can only read/write their own document, 
    // unless the requester is an admin.
    match /userWdboard/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || safeOwnDashboardProfileUpdate(userId);
      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    // Mobile app profile — doc id must match Firebase Auth uid (users/{uid})
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Orders collection (sole source of truth).
    // Dashboard staff/admin can manage all orders. Customers can only access
    // orders that carry their Firebase Auth uid in userId or customer.userId.
    match /orders/{docId} {
      allow create: if isActiveDashboardUser() || canCreateOwnedOrder(request.resource.data);
      allow read: if isActiveDashboardUser() || hasOwner(resource.data);
      allow update: if isActiveDashboardUser()
        || (hasOwner(resource.data) && safeCustomerOrderUpdate());
      allow delete: if isAdmin();

      // Status activity logs (payment verification history, status changes)
      match /status_logs/{logId} {
        allow read: if canReadOrder(docId);
        allow create: if isActiveDashboardUser() || hasOwner(orderData(docId));
        allow update, delete: if false;
      }

      // Re-upload requests sub-collection
      match /reupload_requests/{reqId} {
        allow read: if canReadOrder(docId);
        allow create, update: if isActiveDashboardUser() || hasOwner(orderData(docId));
        allow delete: if false;
      }
    }

    // ✅ COUNTER FOR TDS-001 / TDS-002
    match /counters/{docId} {
      allow read: if isActiveDashboardUser();
      allow create, update: if isActiveDashboardUser();
      allow delete: if false;
    }

    // Insurance orders (legacy - kept for backward compatibility)
    match /insurance_orders/{docId} {
      allow create: if isActiveDashboardUser() || canCreateOwnedOrder(request.resource.data);
      allow read: if isActiveDashboardUser() || hasOwner(resource.data);
      allow update: if isActiveDashboardUser()
        || (hasOwner(resource.data) && safeCustomerOrderUpdate());
      allow delete: if isAdmin();

      // Status activity logs
      match /status_logs/{logId} {
        allow read, create: if isActiveDashboardUser();
      }
    }

    // ✅ AI VERIFICATIONS (Document AI extraction results)
    // Written by Cloud Functions (Admin SDK bypasses rules).
    // Dashboard staff/admin can read all and update (approve/reject).
    match /ai_verifications/{docId} {
      allow read, update: if isActiveDashboardUser();
      allow create: if false;
      allow delete: if isAdmin();
    }

    // ✅ ADDON ORDERS COLLECTION
    match /addOnOrder/{docId} {
      allow create: if isActiveDashboardUser() || canCreateOwnedOrder(request.resource.data);
      allow read: if isActiveDashboardUser() || hasOwner(resource.data);
      allow update: if isActiveDashboardUser()
        || (hasOwner(resource.data) && safeCustomerOrderUpdate());
      allow delete: if isAdmin();
    }

    match /reports/{docId} {
      allow read: if isActiveDashboardUser();
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{docId} {
      allow read, update: if isActiveDashboardUser();
      allow create, delete: if isAdmin();
    }

    match /teamMembers/{docId} {
      allow read, write: if isAdmin();
    }

    match /adminSettings/{docId} {
      allow read, write: if isAdmin();
    }

  }

}
